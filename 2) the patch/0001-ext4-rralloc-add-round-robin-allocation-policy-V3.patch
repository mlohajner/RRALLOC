 fs/ext4/ialloc.c  |   3 +-
 fs/ext4/mballoc.c | 129 ++++++++++++++++++++++++++++++++++++++--------
 fs/ext4/mballoc.h |   4 ++
 fs/ext4/super.c   |  33 +++++++++++-
 5 files changed, 154 insertions(+), 29 deletions(-)

